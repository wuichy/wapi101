# ════════ Reelance App — Variables de entorno ════════
# Copia este archivo a .env y rellena los valores.
# .env NUNCA se sube a git (está en .gitignore).

# ─── Servidor ───
NODE_ENV=development
PORT=3001
# Bind:
#   localhost (127.0.0.1) → solo accesible desde tu Mac (recomendado en local + cloudflared)
#   0.0.0.0               → accesible desde cualquier IP de la red (úsalo en VPS detrás de nginx)
HOST=127.0.0.1

# URL pública de la app (para callbacks OAuth, webhooks, links en mensajes)
#   Local con cloudflared:  https://lucho101.com
#   VPS:                    https://app.tudominio.com
APP_BASE_URL=http://localhost:3001

# ─── Auth ───
# Password de admin (único usuario al inicio; luego se crearán más en la sección Usuarios)
ADMIN_PASSWORD=cambia-esto
# Secret para firmar cookies de sesión (genera 32+ chars random)
SESSION_SECRET=cambia-esto-tambien-32-chars-min

# ─── Base de datos (SQLite local) ───
DB_PATH=./data/reelance.sqlite
UPLOADS_DIR=./data/uploads

# ─── Cifrado de tokens de integraciones ───
# Clave de 32 bytes en hex (genera con: openssl rand -hex 32)
ENCRYPTION_KEY=

# ════════ Integraciones de mensajería ════════

# ─── Meta (WhatsApp Cloud / Messenger / Instagram) ───
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v22.0
META_WEBHOOK_VERIFY_TOKEN=

# WhatsApp Cloud (single-tenant primero)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── TikTok ───
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ════════ IA (genérico — múltiples proveedores intercambiables) ════════
#
# El módulo `src/ai/` expone una interfaz unificada `AIProvider`. La app no
# sabe qué motor está usando — solo le pasa mensajes y recibe respuestas.
# Cambiar de Claude a Gemma local (Ollama) es cambiar AI_PROVIDER + reiniciar.
#
# Proveedores soportados (planeados):
#   anthropic  → Claude (claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5)
#   openai     → GPT (gpt-4o, gpt-4o-mini, etc.)
#   google     → Gemini (gemini-1.5-pro, gemini-1.5-flash)
#   ollama     → Local (gemma2:9b, llama3.1:8b, qwen2.5:14b, etc.)
#   custom     → Cualquier endpoint OpenAI-compatible (vLLM, LM Studio, llama.cpp server)

AI_PROVIDER=anthropic
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# ─── Anthropic (Claude) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ─── OpenAI ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Google Gemini ───
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# ─── Ollama (IA LOCAL — sin internet, sin costo, sin enviar datos a terceros) ───
# Instala Ollama: https://ollama.com  →  ollama pull gemma2:9b
# Corre en background → `ollama serve` (o se inicia solo en Mac)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b

# ─── Custom (cualquier endpoint OpenAI-compatible) ───
# Útil para vLLM, LM Studio, llama.cpp server, Together AI, Groq, etc.
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=
