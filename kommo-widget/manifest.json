{
  "widget": {
    "name": "widget.name",
    "description": "widget.description",
    "short_description": "widget.short_description",
    "version": "1.0.24",
    "interface_version": 2,
    "init_once": true,
    "locale": ["es", "en"],
    "installation": true,
    "support": {
      "link": "https://lucho101.com",
      "email": "noreply@lucho101.com"
    }
  },
  "locations": ["settings", "salesbot_designer"],
  "tour": {
    "is_tour": true,
    "tour_images": {
      "es": ["/images/logo_main.png"],
      "en": ["/images/logo_main.png"]
    },
    "tour_description": "widget.tour_description"
  },
  "settings": {
    "webhook_url": {
      "name": "settings.webhook_url",
      "type": "text",
      "required": true
    }
  },
  "salesbot_designer": {
    "logo": "/images/logo_main.png",
    "reelance_log_outgoing": {
      "name": "Registrar mensaje en Reelance Hub",
      "settings": {
        "message_text": {
          "name": "Texto del mensaje a registrar",
          "type": "text",
          "required": false,
          "default_value": "Escribe aquí el mensaje del bot"
        }
      }
    },
    "reelance_reply_bridge": {
      "name": "Enviar desde Reelance Hub",
      "settings": {
        "message_text": {
          "name": "Mensaje (opcional)",
          "type": "text",
          "required": false,
          "default_value": "Mensaje del agente"
        }
      }
    }
  }
}
